{
  "name": "ranchmind",
  "version": "0.1.0",
  "private": false,
  "description": "Closed-loop agent runtime concept: lobster execution, horse dispatch, human memory.",
  "license": "MIT",
  "scripts": {
    "dev": "node ./scripts/ranchmind.mjs help",
    "build": "node ./scripts/ranchmind.mjs help",
    "lint": "echo No lint configured yet",
    "status": "node ./scripts/ranchmind.mjs status",
    "run:training": "node ./scripts/ranchmind.mjs run-training",
    "register:training": "node ./scripts/ranchmind.mjs register-training --disable-legacy",
    "run:qmt": "node ./scripts/ranchmind.mjs run-qmt",
    "run:qmt:dry": "node ./scripts/ranchmind.mjs run-qmt --dry-run",
    "register:qmt": "node ./scripts/ranchmind.mjs register-qmt",
    "evaluate:scheduling": "node ./scripts/ranchmind.mjs evaluate-scheduling",
    "run:autonomy-loop": "node ./scripts/ranchmind.mjs run-autonomy-loop",
    "ensure:feishu": "node ./scripts/ranchmind.mjs ensure-feishu-runtime",
    "register:feishu": "node ./scripts/ranchmind.mjs register-feishu-watchdog"
  },
  "devDependencies": {
    "express": "^5.2.1"
  }
}
