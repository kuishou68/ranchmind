{
  "example_task": {
    "repoRoot": "./examples",
    "script": "./examples/run-task.ps1"
  },
  "training": {
    "platforms": {
      "win32": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "{{root}}\\examples\\run-task.ps1",
          "-Date",
          "{{date}}",
          "-StartDate",
          "{{startDate}}",
          "-LimitStocks",
          "{{limitStocks}}",
          "-QimenMethod",
          "{{qimenMethod}}",
          "-Haircut",
          "{{haircut}}",
          "-Amplifier",
          "{{amplifier}}",
          "-InvocationSource",
          "{{invocationSource}}"
        ],
        "forceArgs": [
          "-Force"
        ],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": "{{root}}\\state\\tmp\\latest_status.json"
      },
      "darwin": {
        "command": "bash",
        "args": [
          "{{root}}/examples/run-task.sh",
          "--date",
          "{{date}}",
          "--start-date",
          "{{startDate}}",
          "--limit-stocks",
          "{{limitStocks}}",
          "--qimen-method",
          "{{qimenMethod}}",
          "--haircut",
          "{{haircut}}",
          "--amplifier",
          "{{amplifier}}"
        ],
        "forceArgs": [
          "--force"
        ],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": "{{root}}/state/tmp/latest_status.json"
      },
      "linux": {
        "command": "bash",
        "args": [
          "{{root}}/examples/run-task.sh",
          "--date",
          "{{date}}",
          "--start-date",
          "{{startDate}}",
          "--limit-stocks",
          "{{limitStocks}}",
          "--qimen-method",
          "{{qimenMethod}}",
          "--haircut",
          "{{haircut}}",
          "--amplifier",
          "{{amplifier}}"
        ],
        "forceArgs": [
          "--force"
        ],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": "{{root}}/state/tmp/latest_status.json"
      }
    }
  },
  "hermes": {
    "home": "%USERPROFILE%\\.hermes\\runtime",
    "taskName": "Notification Gateway",
    "gatewayLog": "%USERPROFILE%\\.hermes\\runtime\\logs\\gateway.log",
    "platforms": {
      "win32": {
        "taskName": "Notification Gateway",
        "gatewayLog": "%USERPROFILE%\\.hermes\\runtime\\logs\\gateway.log"
      },
      "darwin": {
        "taskName": "Notification Gateway",
        "gatewayLog": "$HOME/.hermes/runtime/logs/gateway.log"
      },
      "linux": {
        "taskName": "Notification Gateway",
        "gatewayLog": "$HOME/.hermes/runtime/logs/gateway.log"
      }
    }
  },
  "ranchmind": {
    "taskPath": "\\RanchMind\\",
    "taskName": "RanchMindDailyTask",
    "taskTime": "10:20"
  },
  "scheduler": {
    "platforms": {
      "win32": {
        "kind": "windows-task",
        "taskPath": "\\RanchMind\\",
        "taskName": "RanchMindDailyTask",
        "taskTime": "10:20"
      },
      "darwin": {
        "kind": "cron",
        "taskName": "RanchMindDailyTask",
        "taskTime": "10:20"
      },
      "linux": {
        "kind": "cron",
        "taskName": "RanchMindDailyTask",
        "taskTime": "10:20"
      }
    }
  },
  "harness": {
    "maxAttempts": 2,
    "retryDelaySeconds": 15,
    "runsRetainDays": 30,
    "evaluator": {
      "acceptStatuses": [
        "ok",
        "skipped"
      ],
      "requiredArtifactsOnOk": [
        "authoritative_status_json",
        "output_json",
        "latest_json"
      ],
      "requiredOutcomeFieldsOnOk": [
        "target_end_date"
      ],
      "metricThresholds": {
        "summary.objective_score": { "min": 0.0 },
        "summary.validation_calendar_sharpe": { "min": 1.2 }
      }
    }
  },
  "schedulingPolicy": {
    "lane": "training",
    "historyScanLimit": 200,
    "feishuSnapshotMaxAgeSeconds": 600
  },
  "autonomyLoop": {
    "trainingHistoryScanLimit": 200,
    "feishuHistoryScanLimit": 200,
    "qmtHistoryScanLimit": 200,
    "minSuccessfulRunsForEvaluation": 5
  },
  "qmt": {
    "platforms": {
      "win32": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "{{root}}\\examples\\run-qmt.ps1",
          "-Date",
          "{{date}}",
          "-OutputJson",
          "{{root}}\\state\\tmp\\qmt-run-output.json"
        ],
        "dryRunArgs": ["-DryRun"],
        "workingDirectory": "{{root}}",
        "outputJsonPath": "{{root}}\\state\\tmp\\qmt-run-output.json",
        "processName": "TargetProcess",
        "executable": "C:\\Path\\To\\Target.exe"
      }
    },
    "scheduler": {
      "kind": "windows-task",
      "taskPath": "\\RanchMind\\",
      "taskName": "RanchMindSecondaryTask",
      "taskTime": "14:30"
    },
    "harness": {
      "maxAttempts": 3,
      "retryDelaySeconds": 15,
      "timeoutSeconds": 900,
      "startupWaitSeconds": 240,
      "timeoutBackoffMultiplier": 20,
      "evaluator": {
        "acceptStatuses": ["ok", "skipped"],
        "requiredArtifactsOnOk": [],
        "requiredOutcomeFieldsOnOk": [],
        "metricThresholds": {}
      }
    }
  },
  "feishuWatchdog": {
    "failureThreshold": 3,
    "taskPath": "\\RanchMind\\",
    "taskName": "RanchMindRuntimeWatchdog",
    "taskTime": "00:00",
    "repeatMinutes": 5,
    "sourceCodexAuthPath": "%USERPROFILE%\\.codex\\auth.json",
    "runtimeHermesAuthPath": "%USERPROFILE%\\.hermes\\runtime\\auth.json",
    "gatewayStatePath": "%USERPROFILE%\\.hermes\\runtime\\gateway_state.json",
    "gatewayPidPath": "%USERPROFILE%\\.hermes\\runtime\\gateway.pid",
    "syncScriptPath": "%USERPROFILE%\\.hermes\\Sync-Auth.ps1",
    "gatewayTaskName": "Notification Gateway",
    "gatewayTaskPath": "\\",
    "syncSkewSeconds": 3600,
    "logTailLines": 200
  }
}
