{
  "kd": {
    "repoRoot": "..\\cocoon-trade\\cocoon-trade",
    "trainingScript": "..\\cocoon-trade\\cocoon-trade\\ops\\windows\\Invoke-OvernightHoldNonTradingFactorTraining.ps1",
    "legacyTaskPath": "\\KD\\",
    "legacyTaskName": "KdNonTradingFactorTrainingDaily"
  },
  "training": {
    "platforms": {
      "win32": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "{{root}}\\..\\cocoon-trade\\cocoon-trade\\ops\\windows\\Invoke-OvernightHoldNonTradingFactorTraining.ps1",
          "-RepoRoot",
          "{{root}}\\..\\cocoon-trade\\cocoon-trade",
          "-Date",
          "{{date}}",
          "-InvocationSource",
          "{{invocationSource}}"
        ],
        "forceArgs": [
          "-Force"
        ],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": "{{root}}\\..\\cocoon-trade\\cocoon-trade\\tmp_overnight_hold_factor_train_nontrading_latest_status.json"
      },
      "darwin": {
        "command": "",
        "args": [],
        "forceArgs": [],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": ""
      },
      "linux": {
        "command": "",
        "args": [],
        "forceArgs": [],
        "workingDirectory": "{{root}}",
        "authoritativeStatusPath": ""
      }
    }
  },
  "hermes": {
    "home": "%USERPROFILE%\\.hermes-windows\\runtime",
    "taskName": "Hermes Gateway",
    "gatewayLog": "%USERPROFILE%\\.hermes-windows\\runtime\\logs\\gateway.log",
    "platforms": {
      "win32": {
        "taskName": "Hermes Gateway",
        "gatewayLog": "%USERPROFILE%\\.hermes-windows\\runtime\\logs\\gateway.log"
      },
      "darwin": {
        "taskName": "Hermes Gateway",
        "gatewayLog": "$HOME/.hermes/runtime/logs/gateway.log"
      },
      "linux": {
        "taskName": "Hermes Gateway",
        "gatewayLog": "$HOME/.hermes/runtime/logs/gateway.log"
      }
    }
  },
  "ranchmind": {
    "taskPath": "\\RanchMind\\",
    "taskName": "RanchMindNonTradingFactorTrainingDaily",
    "taskTime": "10:20"
  },
  "scheduler": {
    "platforms": {
      "win32": {
        "kind": "windows-task",
        "taskPath": "\\RanchMind\\",
        "taskName": "RanchMindNonTradingFactorTrainingDaily",
        "taskTime": "10:20"
      },
      "darwin": {
        "kind": "cron",
        "taskName": "RanchMindNonTradingFactorTrainingDaily",
        "taskTime": "10:20"
      },
      "linux": {
        "kind": "cron",
        "taskName": "RanchMindNonTradingFactorTrainingDaily",
        "taskTime": "10:20"
      }
    }
  },
  "harness": {
    "maxAttempts": 2,
    "retryDelaySeconds": 15,
    "runsRetainDays": 30,
    "evaluator": {
      "acceptStatuses": [
        "ok",
        "skipped"
      ],
      "requiredArtifactsOnOk": [
        "authoritative_status_json",
        "output_json",
        "latest_json"
      ],
      "requiredOutcomeFieldsOnOk": [
        "target_end_date"
      ],
      "metricThresholds": {}
    }
  },
  "schedulingPolicy": {
    "lane": "training",
    "historyScanLimit": 200,
    "feishuSnapshotMaxAgeSeconds": 600
  },
  "autonomyLoop": {
    "trainingHistoryScanLimit": 200,
    "feishuHistoryScanLimit": 200,
    "qmtHistoryScanLimit": 200,
    "minSuccessfulRunsForEvaluation": 5
  },
  "qmt": {
    "platforms": {
      "win32": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "{{root}}\\..\\cocoon-trade\\cocoon-trade\\ops\\windows\\Invoke-KdOpenHumanOvernightNotify.ps1",
          "-RepoRoot",
          "{{root}}\\..\\cocoon-trade\\cocoon-trade",
          "-OutputJson",
          "{{root}}\\state\\tmp\\qmt-run-output.json"
        ],
        "dryRunArgs": ["-NotifyDryRun"],
        "workingDirectory": "{{root}}",
        "outputJsonPath": "{{root}}\\state\\tmp\\qmt-run-output.json"
      }
    },
    "scheduler": {
      "kind": "windows-task",
      "taskPath": "\\RanchMind\\",
      "taskName": "RanchMindOvernightQmtDaily",
      "taskTime": "14:30"
    },
    "harness": {
      "maxAttempts": 2,
      "retryDelaySeconds": 15,
      "timeoutSeconds": 900,
      "evaluator": {
        "acceptStatuses": ["ok", "skipped"],
        "requiredArtifactsOnOk": [],
        "requiredOutcomeFieldsOnOk": [],
        "metricThresholds": {}
      }
    }
  },
  "feishuWatchdog": {
    "failureThreshold": 3,
    "taskPath": "\\RanchMind\\",
    "taskName": "RanchMindFeishuWatchdog",
    "taskTime": "00:00",
    "repeatMinutes": 5,
    "sourceCodexAuthPath": "%USERPROFILE%\\.codex\\auth.json",
    "runtimeHermesAuthPath": "%USERPROFILE%\\.hermes-windows\\runtime\\auth.json",
    "gatewayStatePath": "%USERPROFILE%\\.hermes-windows\\runtime\\gateway_state.json",
    "gatewayPidPath": "%USERPROFILE%\\.hermes-windows\\runtime\\gateway.pid",
    "syncScriptPath": "%USERPROFILE%\\.hermes-windows\\Sync-CodexAuthToHermes.ps1",
    "gatewayTaskName": "Hermes Gateway",
    "gatewayTaskPath": "\\",
    "syncSkewSeconds": 3600,
    "logTailLines": 200
  }
}

